<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:DustInTheWind.ChronoMatrix.Controls"
    xmlns:clockwpf="clr-namespace:DustInTheWind.ClockWpf;assembly=DustInTheWind.ClockWpf">

    <Style TargetType="{x:Type local:Digit46}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Digit46}">

                    <UniformGrid
                        Rows="6"
                        Columns="4">
                        
                        <!-- Row 1 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementA}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementB}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementC}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementD}"
                            Focusable="False" />

                        <!-- Row 2 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementE}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementF}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementG}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementH}"
                            Focusable="False" />

                        <!-- Row 3 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementI}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementJ}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementK}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementL}"
                            Focusable="False" />

                        <!-- Row 4 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementM}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementN}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementO}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementP}"
                            Focusable="False" />

                        <!-- Row 5 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementQ}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementR}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementS}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementT}"
                            Focusable="False" />

                        <!-- Row 6 -->

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementU}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementV}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementW}"
                            Focusable="False" />

                        <clockwpf:AnalogClock
                            ClockTemplate="{TemplateBinding ClockTemplate}"
                            Movement="{TemplateBinding MovementX}"
                            Focusable="False" />

                    </UniformGrid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>